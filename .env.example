# ═══════════════════════════════════════════════════════════════════
# Cardinal_Multi — шаблон конфигурации
# ---------------------------------------------------------------
# 1) Скопируй: cp .env.example .env
# 2) Заполни свои значения
# 3) НЕ добавляй .env в git!
# ═══════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────
# СИСТЕМА
# ───────────────────────────────────────────────────────────────────

# Уровень логирования
# Допустимые значения: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Максимальное количество аккаунтов FunPay
# Диапазон: 1..5 (текущий лимит AccountManager)
MAX_ACCOUNTS=5

# Задержка между HTTP-запросами к FunPay API (секунды, >= 0)
REQUEST_DELAY=1.0


# ───────────────────────────────────────────────────────────────────
# TELEGRAM — главный бот управления
# ───────────────────────────────────────────────────────────────────

# Токен главного Telegram-бота
# Создать бота: https://t.me/BotFather → /newbot
MAIN_TELEGRAM_TOKEN=

# Chat ID владельца (целое число!)
# Узнать свой ID: https://t.me/userinfobot
MAIN_TELEGRAM_CHAT_ID=


# ───────────────────────────────────────────────────────────────────
# МОНИТОРИНГ БАЛАНСА
# ───────────────────────────────────────────────────────────────────

# Порог баланса FunPay для отправки уведомления (рубли, >= 0)
# При балансе НИЖЕ этого значения придёт алерт в Telegram
BALANCE_ALERT_THRESHOLD=100.0


# ───────────────────────────────────────────────────────────────────
# OPENAI (опционально — для AI-ответов на сообщения)
# ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=


# ═══════════════════════════════════════════════════════════════════
# LOLZTEAM MARKET — автозакупка аккаунтов
# ═══════════════════════════════════════════════════════════════════
#
# Режимы работы (приоритет сверху вниз):
#   1) LOLZ_API_TOKEN задан → API-режим (рекомендуется, стабильнее)
#   2) LOLZ_LOGIN + LOLZ_PASSWORD → Playwright-режим (требует: playwright install chromium)
#   3) Ничего не задано → LolzteamModule отключён, ошибок нет
# ═══════════════════════════════════════════════════════════════════

# Bearer-токен Lolzteam Market API
# Получить: https://lolz.live/account/api/get-token
LOLZ_API_TOKEN=

# Логин на lzt.market (только для Playwright-режима)
LOLZ_LOGIN=

# Пароль на lzt.market (только для Playwright-режима)
LOLZ_PASSWORD=

# OAuth — расширенные методы API (опционально)
LOLZ_CLIENT_ID=
LOLZ_CLIENT_SECRET=
LOLZ_SECRET_PHRASE=