
# ─── Логирование ────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ─── Аккаунты ───────────────────────────────────────────
# Максимум 5 аккаунтов
MAX_ACCOUNTS=1

# ─── Задержка запросов (секунды, минимум 1) ─────────────
REQUEST_DELAY=6.0

# ─── Главный Telegram-бот ───────────────────────────────
# Токен бота для управления всеми аккаунтами
# Получить: @BotFather → /newbot
MAIN_TELEGRAM_TOKEN=

# Твой Telegram chat_id
# Получить: @userinfobot
MAIN_TELEGRAM_CHAT_ID=

# ─── Уведомления о балансе ──────────────────────────────
# Уведомление при балансе ниже этой суммы (в рублях)
BALANCE_ALERT_THRESHOLD=100.0

# ─── Lolzteam (заполняется модулем lolzteam) ────────────
LOLZTEAM_TOKEN=

# ─── AI консультант (заполняется модулем ai) ────────────
OPENAI_API_KEY=