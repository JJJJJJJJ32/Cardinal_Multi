# ═══════════════════════════════════════════════════════
# Cardinal_Multi — конфигурация
# Скопируй этот файл в .env и заполни свои значения
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# СИСТЕМА
# ───────────────────────────────────────────────────────

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Максимальное количество аккаунтов FunPay
MAX_ACCOUNTS=10

# Задержка между запросами (сек)
REQUEST_DELAY=1.0

# ───────────────────────────────────────────────────────
# TELEGRAM (основной бот Cardinal_Multi)
# ───────────────────────────────────────────────────────

# Токен основного Telegram бота
# Получить: https://t.me/BotFather
MAIN_TELEGRAM_TOKEN=

# Chat ID владельца (для уведомлений от всех модулей)
# Узнать: https://t.me/userinfobot
MAIN_TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────────────────
# МОНИТОРИНГ БАЛАНСА
# ───────────────────────────────────────────────────────

# Порог баланса FunPay для уведомления (руб.)
BALANCE_ALERT_THRESHOLD=100.0

# ───────────────────────────────────────────────────────
# OPENAI (опционально — для AI-ответов)
# ───────────────────────────────────────────────────────

OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════
# LOLZTEAM АВТОЗАКУПКА — Модуль 2
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# Режим API (основной — рекомендуется)
# ───────────────────────────────────────────────────────

# Bearer токен Lolzteam Market API
# Получить: https://lolz.live/account/api/get-token
# Если задан — используется API режим (стабильнее)
LOLZ_API_TOKEN=

# ───────────────────────────────────────────────────────
# Режим Playwright (fallback)
# Используется ТОЛЬКО если LOLZ_API_TOKEN не задан
# ───────────────────────────────────────────────────────

# Логин на lzt.market
LOLZ_LOGIN=

# Пароль на lzt.market
LOLZ_PASSWORD=

# ───────────────────────────────────────────────────────
# OAuth / расширенные методы API (опционально)
# Нужны только для отдельных методов Lolzteam API
# ───────────────────────────────────────────────────────

# Client ID (для OAuth авторизации)
LOLZ_CLIENT_ID=

# Client Secret (для OAuth авторизации)
LOLZ_CLIENT_SECRET=

# Secret Phrase (дополнительная защита аккаунта)
LOLZ_SECRET_PHRASE=

# ───────────────────────────────────────────────────────
# ПРИМЕЧАНИЕ ПО LOLZTEAM
# ───────────────────────────────────────────────────────
#
# Приоритет режимов:
#   1. LOLZ_API_TOKEN задан → API режим (рекомендуется)
#   2. LOLZ_LOGIN + LOLZ_PASSWORD → Playwright режим
#   3. Ничего не задано → LolzteamModule не запускается
#
# Playwright режим:
#   - Cookies сохраняются в: data/lolz_session.json
#   - Медленнее API режима
#   - Требует: playwright install chromium
#
# ═══════════════════════════════════════════════════════