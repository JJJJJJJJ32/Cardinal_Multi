
# ── Telegram (главный бот) ───────────────────────────────────
# Получить у @BotFather
MAIN_TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram User ID владельца (получить у @userinfobot)
# Это единственный ID, которому разрешено управлять ботом
MAIN_TELEGRAM_CHAT_ID=YOUR_TELEGRAM_USER_ID_HERE

# ── Логирование ──────────────────────────────────────────────
# Допустимые: DEBUG, INFO, WARNING, ERROR
# WARNING: DEBUG в продакшене раскрывает чувствительные данные!
LOG_LEVEL=INFO

# Включить расширенные трейсбеки (ТОЛЬКО для локальной отладки!)
# 0 = выключено (продакшен-дефолт), 1 = включено
CARDINAL_MULTI_LOG_DIAGNOSE=0
CARDINAL_MULTI_LOG_BACKTRACE=0

# ── OpenAI (если используется) ───────────────────────────────
# sk-... ключ из platform.openai.com
OPENAI_API_KEY=

# ── Lolzteam (если используется) ────────────────────────────
LOLZTEAM_TOKEN=
LOLZTEAM_FORUM_TOKEN=

# ── База данных ──────────────────────────────────────────────
# По умолчанию SQLite, путь менять не рекомендуется
# DB_PATH=data/cardinal_multi.db

# ── Ключ шифрования ──────────────────────────────────────────
# НЕ задавать вручную! Генерируется автоматически в data/secret.key
# SECRET_KEY_PATH=data/secret.key

# ── Прокси (опционально) ─────────────────────────────────────
# PROXY_URL=socks5://user:pass@host:port